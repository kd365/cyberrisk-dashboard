# CyberRisk Dashboard - Frontend Environment
# Copy this file to .env and fill in your values
# These values are embedded at build time

# API URL (relative for CloudFront routing)
REACT_APP_API_URL=/api

# AWS Region
REACT_APP_AWS_REGION=us-west-2

# Cognito Authentication
# Get these from AWS Console > Cognito > User Pools > Your Pool
REACT_APP_COGNITO_USER_POOL_ID=us-west-2_XXXXXXXXX
REACT_APP_COGNITO_CLIENT_ID=your-client-id-here
